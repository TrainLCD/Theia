# THQ upstream WebSocket. Read by the Node server only; the browser
# connects to /api/thq-events (SSE) so the token never leaves the host.
THQ_WS_URL=
# Observer token (THQ_OBSERVER_AUTH_TOKEN on the THQ server). Required:
# without it the handshake is rejected with HTTP 401.
THQ_WS_TOKEN=
# Subscriber identifier sent in the initial {type: "subscribe"} frame.
# Defaults to "theia" if unset.
THQ_SUBSCRIBE_DEVICE=

# TrainLCD GraphQL endpoint used to resolve line_id -> name / color.
# Defaults to the staging endpoint.
TRAINLCD_GRAPHQL_URL=

# THQ GraphQL endpoint used for the initial screen snapshot (/api/thq-snapshot).
# Read by the Node server only; authenticated with THQ_WS_TOKEN as a bearer
# token, so the token never leaves the host. Defaults to
# https://thq.trainlcd.app/graphql.
THQ_GRAPHQL_URL=
